# ─── Safar AI Environment Variables ─────────────────────────────────────────
# Copy this to .env.local and fill in the values.
# All services gracefully degrade — app works with ONLY Firebase + Gemini.

# ─── Firebase (Auth + Firestore — Spark/Free plan) ─────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Firebase Admin SDK (server-side, single-line JSON) ────────────────────
FIREBASE_SERVICE_ACCOUNT_KEY=

# ─── Google Gemini AI (FREE tier: 60 req/min) ──────────────────────────────
# Get key: https://aistudio.google.com/apikey
# This powers: AI trip planning, price estimation, activity recommendations
GEMINI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=  # Same value as GEMINI_API_KEY (needed by @ai-sdk/google)

# ─── Optional: Amadeus Flight API (FREE 2,000 req/month) ──────────────────
# Sign up: https://developers.amadeus.com → Create account → Get API keys
# Returns real-time flight prices from 400+ airlines
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_ENV=test  # Use "production" for live data (requires Amadeus approval)

# ─── Optional: SerpAPI (Google Flights data, $50/mo for 5K searches) ──────
SERPAPI_KEY=

# ─── Optional: Google Places (hotels + activities, 5K free req/month) ─────
# Enable in Google Cloud Console → Places API (New)
GOOGLE_PLACES_API_KEY=

# ─── Optional: Booking.com Affiliate (FREE — earn commission) ─────────────
# Sign up: https://www.booking.com/affiliate-program/v2/index.html
BOOKING_AFFILIATE_ID=

# ─── Optional: Travelpayouts (FREE — earn 30% affiliate commission) ──────
# Sign up: https://www.travelpayouts.com
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# ─── Optional: Analytics & Monetization ──────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT=
